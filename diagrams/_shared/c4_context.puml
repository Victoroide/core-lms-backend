@startuml C4_Context
' IMPORTANTE: NO incluir global_style.iuml en C4.
' C4-PlantUML inyecta su propio skinparam.
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml
LAYOUT_WITH_LEGEND()

title AxiomLMS — C4 Level 1: System Context Diagram

Person(student, "Estudiante", "Estudiante universitario que\nrinde quizzes, entrega asignaciones\ny consulta planes adaptativos.")
Person(tutor, "Tutor", "Docente que gestiona la jerarquía\nacadémica, califica entregas y\nconsulta dashboards analíticos.")

System(axiomLMS, "AxiomLMS", "Plataforma LMS con evaluación\nadaptativa, proctoring y grafos\ncognitivos.")

System_Ext(awsBedrock, "AWS Bedrock", "Servicio de IA generativa\n(Amazon Nova Micro) para planes\nadaptativos y clasificación cognitiva.")
System_Ext(awsS3, "AWS S3", "Almacenamiento de objetos para\nrecursos de lecciones y entregas\nde estudiantes.")

Rel_D(student, axiomLMS, "Usa", "HTTPS / JWT")
Rel_D(tutor, axiomLMS, "Usa", "HTTPS / JWT")
Rel_D(axiomLMS, awsBedrock, "Solicita clasificación\ny planes adaptativos", "HTTPS / BAML")
Rel_D(axiomLMS, awsS3, "Almacena y recupera\narchivos", "HTTPS / S3 API")

@enduml
