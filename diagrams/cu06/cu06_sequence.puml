@startuml CU06_Sequence
!include ../_shared/global_style.iuml
skinparam responseMessageBelowArrow true
autonumber "<b>"

title CU-06 — Entregar asignación: Diagrama de Secuencia

actor Estudiante as Actor
boundary "Angular\nSubmissionComponent" as Angular
control "SubmissionViewSet\n(submission_viewset.py:15)" as ViewSet
entity "SubmissionSerializer\n(submission_serializer.py)" as Serializer
entity "Submission\n(submission_model.py:8)" as Model
entity "submission_upload_path\n(storage_service.py:4)" as StorageFunc
database "AWS S3" as S3
database "NeonDB\nPostgreSQL" as DB

Actor -> Angular : Seleccionar archivo\npara assignment {id}
Angular -> ViewSet : POST /api/v1/submissions/\n(multipart/form-data)\nAuthorization: Bearer <token>

ViewSet -> ViewSet : get_permissions() → [IsStudent()]

alt user.role != "STUDENT"
    ViewSet --> Angular : HTTP 403\n"Access restricted to students."
else user.role == "STUDENT"
    ViewSet -> Serializer : SubmissionSerializer(data=request.data)
    Serializer -> Serializer : is_valid(raise_exception=True)

    alt validation fails
        Serializer --> ViewSet : raise ValidationError
        ViewSet --> Angular : HTTP 400\n{ field errors }
    else validation passes
        Serializer -> Model : Submission(**validated_data)
        Model -> StorageFunc : submission_upload_path(instance, filename)
        StorageFunc --> Model : "submissions/{student_id}/{filename}"
        Model -> S3 : PUT object at\nsubmissions/{student_id}/{filename}
        S3 --> Model : OK
        Model -> DB : INSERT INTO submission\n(assignment_id, student_id, file,\nsubmitted_at, is_deleted, deleted_at)
        
        alt IntegrityError (unique_together violation)
            DB --> Model : IntegrityError
            Model --> Serializer : raise
            ViewSet --> Angular : HTTP 400\n"Duplicate submission for this assignment."
        else insert OK
            DB --> Model : Submission row
            Model --> Serializer : Submission instance
            Serializer --> ViewSet : serialized data
            ViewSet --> Angular : HTTP 201\n{ id, assignment, student, file, submitted_at }
        end
    end
end

Angular --> Actor : Confirmar entrega exitosa

@enduml
