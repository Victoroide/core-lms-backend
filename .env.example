SECRET_KEY=
DEBUG=
ALLOWED_HOSTS=

POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=

# NeonDB connection string (production and local development against NeonDB).
# Copy the full connection string from neon.tech dashboard:
# Project -> Connection Details -> Connection string.
# The query string parameters (sslmode, channel_binding) must be preserved as-is.
DATABASE_URL=

AXIOM_ENGINE_URL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

# Comma-separated list of allowed CORS origins. Example:
# CORS_ALLOWED_ORIGINS=https://yourfrontend.com,http://localhost:4200
CORS_ALLOWED_ORIGINS=

# Python logging level. Options: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# Set True to redirect all HTTP to HTTPS in production.
SECURE_SSL_REDIRECT=False
